client_secret = "Lz3CzmzGYdcQPiptyfwi0PoPu6DLB2CebNvmOiEHcRAS0WkwWzrEFWGmLoClsdndol1xt92aMVXZdFH73gQRwvAxonU3LhaOtPNGoxSZykD019ORJRZhqIF1zIOTb0e9"



curl -X POST -d "client_id=xbm4Wv3db64dTvrXSFrLkBS88eErzp1l7aYXTMT3&client_secret=Lz3CzmzGYdcQPiptyfwi0PoPu6DLB2CebNvmOiEHcRAS0WkwWzrEFWGmLoClsdndol1xt92aMVXZdFH73gQRwvAxonU3LhaOtPNGoxSZykD019ORJRZhqIF1zIOTb0e9&grant_type=password&username=admin&password=admin" http://localhost:8000/auth/token

