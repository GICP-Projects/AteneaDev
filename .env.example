# SCRAPY CONFIGURATION
WEBSHARE_ENABLED='False'
WEBSHARE_USER=''
WEBSHARE_PASSWORD=''

# DJANGO CONFIGURATION
DJANGO_SETTINGS_MODULE=
DJANGO_LOG_LEVEL=INFO
DJANGO_SECRET_KEY=
DJANGO_SERVER_TIMEZONE=Europe/Madrid
GOOGLE_OAUTH2_CLIENT=
GOOGLE_OAUTH2_SECRET=
JWT_SIGNATURE_SECRET=
ACCESS_TOKEN_EXPIRE_SECONDS=86400
REFRESH_TOKEN_EXPIRE_SECONDS=99999999

DEPLOYMENT_UNIQUE_SUFFIX= # To avoid collision between different deployments sharing Elastic/Qdrant

# ELASTIC CONFIGURATION
ELASTICSEARCH_HOST=
ELASTICSEARCH_APIKEY_ID=
ELASTICSEARCH_APIKEY_API_KEY=

# POSTGRESQL CONFIGURATION
POSTGRES_HOST=
POSTGRES_PORT=5432
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=
PGADMIN_DEFAULT_EMAIL=admin@gicp.es
PGADMIN_DEFAULT_PASSWORD=admin

# REDIS CONFIGURATION
REDIS_HOST=
REDIS_PORT=6379
REDIS_PASSWORD=

# MICROSERVICES CONFIGURATION
NER_SERVICE_API_KEY=
NER_SERVICE_HOST=atenea_services_net
NER_SERVICE_PORT=80
NER_SERVICE_MAX_DATA_BY_REQUEST=5000
OPENAI_EMBEDDINGS_BASE_URL=http://localhost:28333/v1
OPENAI_EMBEDDINGS_API_KEY=
OPENAI_EMBEDDINGS_MODEL=Qwen/Qwen3-Embedding-4B
OPENAI_EMBEDDINGS_MAX_DATA_BY_REQUEST=500
OPENAI_EMBEDDINGS_MAX_PARALLEL_REQUESTS=10
OPENAI_EMBEDDINGS_TIMEOUT=60
# Optional. Leave empty to let the provider return its default embedding size.
# Recommended for vLLM/Ollama unless you know the backend supports `dimensions`.
OPENAI_EMBEDDINGS_DIMENSIONS=
EMBEDDINGS_PENDING_TIMEOUT_SECONDS=900
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=
QDRANT_TIMEOUT=60
# Search-time tuning (optional):
# - hnsw_ef: larger -> better recall, slower search.
# - exact: true -> exact kNN (slow, useful for quality evaluation only).
QDRANT_SEARCH_HNSW_EF=
QDRANT_SEARCH_EXACT=
# Collection HNSW defaults for NEW collections created by Atenea (optional):
# Existing collections are NOT modified by these values.
QDRANT_HNSW_M=
QDRANT_HNSW_EF_CONSTRUCT=
QDRANT_HNSW_FULL_SCAN_THRESHOLD=
QDRANT_UPSERT_BATCH_SIZE=400
QDRANT_UPSERT_MAX_RETRIES=2
QDRANT_UPSERT_RETRY_DELAY_SECONDS=2
QDRANT_COLLECTION_MESSAGE_SEARCH=msg_search_embeddings
QDRANT_COLLECTION_CATEGORIZATION=categorization_embeddings
SENTIMENT_SERVICE_API_KEY=
SENTIMENT_SERVICE_HOST=atenea_services_net
SENTIMENT_SERVICE_PORT=80
SENTIMENT_SERVICE_MAX_DATA_BY_REQUEST=5000
